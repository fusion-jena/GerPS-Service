@base <https://w3id.org/gerps/ontology/service/> .

<https://w3id.org/gerps/ontology/service/> rdf:type owl:Ontology ;
                                            owl:imports gpd: ,
                                                        gpp: ;
                                            dct:abstract "Add-on module mapping the FIM building block Leistung (master text and service profile) from the XZuFi standard. It enriches the Leistung class of the GerPS-Process ontology and links it to processes, data schemas and code lists of the GerPS ecosystem."@en ,
                                                         "Add-on-Modul zur Abbildung des FIM-Bausteins Leistung (Stammtext und Leistungssteckbrief) aus dem XZuFi-Standard. Reichert die Klasse Leistung der GerPS-Process-Ontologie an und verknüpft sie mit Prozessen, Datenschemata und Codelisten des GerPS-Ökosystems."@de ;
                                            dct:contributor "Norman Klewer" ,
                                                            "Heinz Conti Zacherl" ,
                                                            "Maximilian Enderling" ;
                                            dct:creator "openDVA" ;
                                            dct:license <http://creativecommons.org/licenses/by/4.0/> ;
                                            dct:title "GerPS-Leistung"@de ,
                                                      "GerPS-Service"@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/abstract
dct:abstract rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dct:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dct:license rdf:type owl:AnnotationProperty .


###  https://w3id.org/gerps/ontology/service/GPS_0000068
gps:GPS_0000068 rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dct:title rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#anyURI
xsd:anyURI rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#dateTime
xsd:dateTime rdf:type rdfs:Datatype .


